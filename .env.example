# 標準出力に出すか
LOG_TO_STDOUT=true

# Application Insights に送るか
LOG_TO_APPINSIGHTS=false

# App Insights の接続文字列（送信先リソースのアドレス。認証情報ではない）
# 認証は Entra ID （DefaultAzureCredential）で統一。ローカルは az login、本番はマネージド ID。
# 実行プリンシパルに「Monitoring Metrics Publisher」ロール + リソース側で DisableLocalAuth=true を前提とする
APPLICATIONINSIGHTS_CONNECTION_STRING=

# App Insights 上で表示されるアプリケーション識別名（複数アプリを 1 つのリソースに送る場合に区別できる）
LOG_SERVICE_NAME=app-baseline

# 出力するログレベルの閾値（DEBUG / INFO / WARNING / ERROR / CRITICAL）
# ここで指定したレベル以上のログだけが出力される（例: WARNING にすると INFO/DEBUG は破棄）
LOG_LEVEL=INFO
